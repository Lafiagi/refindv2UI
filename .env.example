# API Configuration
VITE_API_URL='http://localhost:8000/api'
VITE_GOOGLE_CLIENT_ID='your-google-client-id'

# Cloudinary Configuration
# Get these values from your Cloudinary dashboard: https://cloudinary.com/console

# Your Cloudinary cloud name (required)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
# Upload preset for unsigned uploads (required for client-side uploads)
# Create this in Cloudinary dashboard: Settings > Upload > Upload presets
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# API Secret (NEVER expose this in client-side code!)
# This should only be used on the server-side
# CLOUDINARY_API_SECRET=your-api-secret